{
  "campaign_name": "Legacy Ops",
  "global_hint": "System Breach Detected. Multiple logs exist. Verify targets before acting.",
  "filesystem": {
    "etc": {
      "vault": { "fragment.txt": { "content": "FLAG{fragmented_auth_bypassed}" } },
      "nginx": { "nginx.conf": { "content": "listen 80;\n# CORRUPTED", "metadata": {"permissions": "644"} } },
      "shadow": { "content": "root:$6$...:19000:0:99999:7:::", "metadata": {"permissions": "777"} }
    },
    "var": {
      "log": {
        "auth.log": { "content": "SYSTEM_ALERT_PAYLOAD: REVDT1lfRkFLRV9GTEFHX0lHTk9SRQ==" },
        "syslog.txt": { "content": "08:08 SYSTEM_ALERT_PAYLOAD: NDY0YzQxNDc3YjZkNzU2Yzc0Njk1ZjZjNjE3OTY1NzI1ZjYzNzI3OTcwNzQ2ZjVmNjM3MjYxNjM2YjY1NjQ3ZA==\n" }
      }
    },
    "mnt": { "backups": { "nginx_clean.conf": { "content": "listen 80;\nserver_name secure.local;" } } },
    "tmp": { "sysupdater": { "content": "ELF... malicious payload...", "metadata": {"is_malware": true} }, "safe_cache.tmp": { "content": "cache data..." } }
  },
  "tasks": [
    {
      "task_id": "phase1",
      "description": "Phase 1 (Recon): Locate the initial fragmented auth flag hidden in the vault.",
      "grader": "exact_match",
      "expected_output": "FLAG{fragmented_auth_bypassed}",
      "score": 0.15
    },
    {
      "task_id": "phase2",
      "description": "Phase 2 (Crypto): Extract and decode the multi-layer base64/hex payload from the syslog.",
      "grader": "exact_match",
      "expected_output": "FLAG{multi_layer_crypto_cracked}",
      "score": 0.15
    },
    {
      "task_id": "phase3",
      "description": "Phase 3 (Privilege): Inspect the system environment variables to secure the root session.",
      "grader": "exact_match",
      "expected_output": "FLAG{root_environment_secured}",
      "score": 0.15
    },
    {
      "task_id": "phase4",
      "description": "Phase 4 (Integrity): Restore the corrupted nginx.conf file using the clean backup.",
      "grader": "exact_match",
      "expected_output": "FLAG{integrity_recovered}",
      "score": 0.15
    },
    {
      "task_id": "phase5",
      "description": "Phase 5 (Hardening): Lock down the /etc/shadow file permissions to strict 600.",
      "grader": "exact_match",
      "expected_output": "FLAG{access_control_restored}",
      "score": 0.15
    },
    {
      "task_id": "phase6",
      "description": "Phase 6 (Purge): Quarantine and permanently remove the 'sysupdater' malware binary.",
      "grader": "exact_match",
      "expected_output": "FLAG{threat_neutralized}",
      "score": 0.15
    }
  ]
}